{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.claudekit.dev/handoff.schema.json",
  "title": "Session Handoff",
  "description": "Plain language session-end summary written to project-state and surfaced at the next session's pre-flight.",
  "type": "object",
  "properties": {
    "session_id": { "$ref": "_defs.schema.json#/$defs/session_id" },
    "what_was_done": { "type": "string" },
    "key_decisions": {
      "type": "array",
      "items": { "$ref": "_defs.schema.json#/$defs/decision_record" }
    },
    "dependencies_added": {
      "type": "array",
      "items": { "$ref": "_defs.schema.json#/$defs/dependency_entry" }
    },
    "next_session_notes": { "type": "string" },
    "flags_raised": {
      "type": "array",
      "items": { "$ref": "_defs.schema.json#/$defs/flag_id" }
    },
    "incomplete_tasks": {
      "type": "array",
      "items": { "$ref": "_defs.schema.json#/$defs/task_id" }
    }
  },
  "required": [
    "session_id",
    "what_was_done",
    "next_session_notes"
  ],
  "additionalProperties": false
}
