{
  "id": "guardrails-solo",
  "framework": "guardrails",
  "variant": "solo",
  "name": "Guardrails (Solo)",
  "description": "Security, compliance and privacy controls for solo AI-assisted development. Prevents credential leaks, enforces governance, creates audit records.",
  "version": "1.0.0",
  "source_repo": "github.com/ClaudeKit-Framework/claudekit-guardrails",
  "source_ref": "main",
  "requires_commons": ">=1.0.0",
  "compatible_with": ["runner"],
  "incompatible_with": ["guardrails-team"],
  "files": [
    {
      "source": "guardrails-solo/CLAUDE.md",
      "destination": "CLAUDE.md",
      "conflict_strategy": "merge"
    },
    {
      "source": "guardrails-solo/.claude/settings.json",
      "destination": ".claude/settings.json",
      "conflict_strategy": "merge"
    },
    {
      "source": "guardrails-solo/.claudeignore",
      "destination": ".claudeignore",
      "conflict_strategy": "append"
    },
    {
      "source": "guardrails-solo/.gitignore",
      "destination": ".gitignore",
      "conflict_strategy": "append"
    },
    {
      "source": "guardrails-solo/.claude/commands/create-adr.md",
      "destination": ".claude/commands/create-adr.md",
      "conflict_strategy": "create_only"
    },
    {
      "source": "guardrails-solo/docs/decisions/0000-template.md",
      "destination": "docs/decisions/0000-template.md",
      "conflict_strategy": "create_only"
    },
    {
      "source": "guardrails-solo/docs/decisions/README.md",
      "destination": "docs/decisions/README.md",
      "conflict_strategy": "create_only"
    },
    {
      "source": "guardrails-solo/SECURITY-QUICK-REF.md",
      "destination": "SECURITY-QUICK-REF.md",
      "conflict_strategy": "create_only"
    }
  ],
  "post_install_actions": [
    {
      "action_id": "action-001",
      "description": "Open CLAUDE.md and fill in Section 0 — your stack, test command, lint command, and key directories.",
      "why": "CLAUDE.md Section 0 is blank by design. Claude Code needs your project context before it can apply the security rules correctly.",
      "estimated_minutes": 5
    },
    {
      "action_id": "action-002",
      "description": "Review .claude/settings.json and add your project's test, lint, and build commands to the allow list.",
      "why": "The allow list ships with common defaults. Your specific commands will not be auto-approved until added.",
      "estimated_minutes": 5
    }
  ],
  "commands": [
    { "name": "/create-adr", "description": "Record an architectural decision." }
  ]
}
